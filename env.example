# Environment Configuration
NODE_ENV=development

# API Configuration
VITE_API_BASE_URL=http://localhost:8000

# Google OAuth Configuration
VITE_GOOGLE_OAUTH_CLIENT_ID=your_google_client_id_here
VITE_GOOGLE_OAUTH_REDIRECT_URI=http://localhost:5173/auth/google/callback

# Production URLs (update these for your deployment)
# VITE_API_BASE_URL=https://api.aeropoints.com
# VITE_GOOGLE_OAUTH_REDIRECT_URI=https://aeropoints.com/auth/google/callback

# Backend Environment Variables (for reference)
# These should be set in your backend deployment:

# Database Configuration
# DATABASE_URL=postgresql://user:password@localhost:5432/aeropoints

# JWT Configuration  
# JWT_SECRET_KEY=your_super_secret_jwt_key_here
# JWT_ALGORITHM=HS256
# ACCESS_TOKEN_EXPIRE_MINUTES=30

# OAuth Configuration
# GOOGLE_OAUTH_CLIENT_ID=your_google_client_id_here
# GOOGLE_OAUTH_CLIENT_SECRET=your_google_client_secret_here

# Seats.aero API
# SEATS_AERO_API_KEY=your_seats_aero_api_key

# CORS Configuration
# ALLOWED_ORIGINS=["http://localhost:5173", "https://aeropoints.com"]

# Email Configuration (if using email features)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USERNAME=your_email@gmail.com
# SMTP_PASSWORD=your_app_password

# Redis Configuration (if using caching)
# REDIS_URL=redis://localhost:6379

# Monitoring & Logging
# SENTRY_DSN=your_sentry_dsn_here
# LOG_LEVEL=INFO 